#!/bin/bash
#
# Iksir installer
#
# Generates systemd service files, creates XDG directories, installs CLI wrapper.
# Run once to install, run again to update after pulling changes.
#
# Usage:
#   ./install              # interactive, prompts for config
#   ./install --defaults   # non-interactive, uses sensible defaults
#
# Directory layout (XDG conventions):
#   ~/.iksir/src/                  Source code (this repo)
#   ~/.config/iksir/               Configuration (iksir.json, AGENTS.md)
#   ~/.local/share/iksir/          Data (SQLite database)
#   ~/.local/state/iksir/          Logs
#   ~/.local/bin/iksir             CLI wrapper
#
# Services installed:
#   iksir-mcp.service     — PM-MCP HTTP server (tools for orchestrators)
#   iksir-agent.service   — Agent runtime (OpenCode server)
#   iksir.service         — Iksir daemon (session lifecycle, messaging, git)
#
# Optional:
#   iksir-proxy.service   — SOCKS5 proxy (WireGuard + gost)

set -euo pipefail

# =============================================================================
# Detect environment
# =============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CURRENT_USER="$(whoami)"
HOME_DIR="$(eval echo ~$CURRENT_USER)"

# =============================================================================
# XDG defaults
# =============================================================================

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME_DIR/.config}"
XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME_DIR/.local/share}"
XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME_DIR/.local/state}"
BIN_DIR="$HOME_DIR/.local/bin"

# =============================================================================
# Defaults
# =============================================================================

REPO_PATH="$SCRIPT_DIR"
DENO_BIN="${HOME_DIR}/.deno/bin/deno"
OPENCODE_BIN="${HOME_DIR}/.opencode/bin/opencode"
AGENT_PORT="4096"
MCP_PORT="3100"
CONFIG_DIR="$XDG_CONFIG_HOME/iksir"
DATA_DIR="$XDG_DATA_HOME/iksir"
STATE_DIR="$XDG_STATE_HOME/iksir"
INSTALL_PROXY="no"
PROXY_BIN="/usr/local/bin/gost"
PROXY_WG_IFACE="wg0"

# =============================================================================
# Helpers
# =============================================================================

BOLD="\033[1m"
RESET="\033[0m"
info()  { echo -e "\033[36m[iksir]\033[0m $*"; }
warn()  { echo -e "\033[33m[iksir]\033[0m $*"; }
error() { echo -e "\033[31m[iksir]\033[0m $*" >&2; }
die()   { error "$@"; exit 1; }

prompt() {
  local var="$1" prompt_text="$2" default="$3"
  if [[ "${NONINTERACTIVE:-}" == "1" ]]; then
    eval "$var=\"$default\""
    return
  fi
  read -rp "$(echo -e "\033[36m[iksir]\033[0m $prompt_text [$default]: ")" value
  eval "$var=\"${value:-$default}\""
}

check_bin() {
  local name="$1" path="$2"
  if [[ ! -x "$path" ]]; then
    warn "$name not found at $path"
    return 1
  fi
  return 0
}

# =============================================================================
# Parse args
# =============================================================================

NONINTERACTIVE=0
for arg in "$@"; do
  case "$arg" in
    --defaults) NONINTERACTIVE=1 ;;
    --help|-h)
      echo "Usage: ./install [--defaults]"
      echo ""
      echo "  --defaults   Non-interactive, use sensible defaults"
      echo ""
      echo "Generates systemd services, creates directories, installs CLI."
      echo "Run again after pulling updates to re-deploy."
      exit 0
      ;;
    *) die "Unknown argument: $arg" ;;
  esac
done

# =============================================================================
# Gather configuration
# =============================================================================

info "Iksir installer"
echo ""

prompt REPO_PATH    "Repository path"        "$REPO_PATH"
prompt DENO_BIN     "Deno binary path"       "$DENO_BIN"
prompt OPENCODE_BIN "OpenCode binary path"   "$OPENCODE_BIN"
prompt AGENT_PORT   "Agent runtime port"     "$AGENT_PORT"
prompt MCP_PORT     "MCP server port"        "$MCP_PORT"

if [[ "$NONINTERACTIVE" != "1" ]]; then
  read -rp "$(echo -e "\033[36m[iksir]\033[0m Install SOCKS5 proxy service? (for Telegram in restricted regions) [no]: ")" INSTALL_PROXY
  INSTALL_PROXY="${INSTALL_PROXY:-no}"
  if [[ "$INSTALL_PROXY" =~ ^[Yy] ]]; then
    INSTALL_PROXY="yes"
    prompt PROXY_BIN      "gost binary path"     "$PROXY_BIN"
    prompt PROXY_WG_IFACE "WireGuard interface"  "$PROXY_WG_IFACE"
  fi
fi

# =============================================================================
# Validate
# =============================================================================

[[ -d "$REPO_PATH" ]]             || die "Repository not found: $REPO_PATH"
[[ -f "$REPO_PATH/src/main.ts" ]] || die "Not an Iksir repo: $REPO_PATH/src/main.ts missing"
check_bin "Deno"     "$DENO_BIN"     || die "Install Deno: https://docs.deno.com/runtime/getting_started/installation/"
check_bin "OpenCode" "$OPENCODE_BIN" || die "Install OpenCode: https://opencode.ai"

if [[ "$INSTALL_PROXY" == "yes" ]]; then
  check_bin "gost" "$PROXY_BIN" || die "gost not found. Install: https://github.com/ginuerzh/gost"
  command -v wg-quick &>/dev/null || die "wg-quick not found. Install: apt install wireguard-tools"
fi

# =============================================================================
# Create directories
# =============================================================================

mkdir -p "$CONFIG_DIR" "$DATA_DIR" "$STATE_DIR" "$BIN_DIR"
info "Config:  $CONFIG_DIR"
info "Data:    $DATA_DIR"
info "Logs:    $STATE_DIR"

# Copy example config if none exists
if [[ ! -f "$CONFIG_DIR/iksir.json" ]]; then
  if [[ -f "$REPO_PATH/iksir.json.example" ]]; then
    cp "$REPO_PATH/iksir.json.example" "$CONFIG_DIR/iksir.json"
    info "Created $CONFIG_DIR/iksir.json from example"
  fi
fi

# Copy agents.md example if none exists
if [[ ! -f "$CONFIG_DIR/AGENTS.md" ]]; then
  if [[ -f "$REPO_PATH/agents.md.example" ]]; then
    cp "$REPO_PATH/agents.md.example" "$CONFIG_DIR/AGENTS.md"
    info "Created $CONFIG_DIR/AGENTS.md from example"
  fi
fi

# Copy .env example if none exists
if [[ ! -f "$REPO_PATH/.env" ]]; then
  if [[ -f "$REPO_PATH/.env.example" ]]; then
    cp "$REPO_PATH/.env.example" "$REPO_PATH/.env"
    info "Created .env from example"
  fi
fi

# =============================================================================
# Sync prompts and plugins
# =============================================================================

info "Syncing agent prompts..."
AGENT_PROMPT_DIR="${XDG_CONFIG_HOME}/opencode/agent"
PLUGIN_DIR="${XDG_CONFIG_HOME}/opencode/plugins"
mkdir -p "$AGENT_PROMPT_DIR" "$PLUGIN_DIR"

for file in "$REPO_PATH"/prompts/iksir-*.md; do
  [[ -f "$file" ]] && cp "$file" "$AGENT_PROMPT_DIR/$(basename "$file")"
done

for file in "$REPO_PATH"/plugins/*.ts; do
  [[ -f "$file" ]] && cp "$file" "$PLUGIN_DIR/$(basename "$file")"
done

# =============================================================================
# Install CLI wrapper
# =============================================================================

cat > "$BIN_DIR/iksir" <<EOF
#!/bin/bash
exec "$DENO_BIN" run --allow-all --env="$REPO_PATH/.env" "$REPO_PATH/src/cli.ts" "\$@"
EOF
chmod +x "$BIN_DIR/iksir"
info "Installed CLI: $BIN_DIR/iksir"

# Check if BIN_DIR is on PATH
if [[ ":$PATH:" != *":$BIN_DIR:"* ]]; then
  warn "$BIN_DIR is not on your PATH. Add to your shell profile:"
  warn "  export PATH=\"$BIN_DIR:\$PATH\""
fi

# =============================================================================
# Detect systemd mode (user-level unless running as root)
# =============================================================================

if [[ "$EUID" -eq 0 ]]; then
  SYSTEMD_DIR="/etc/systemd/system"
  SYSTEMCTL="systemctl"
  info "Running as root: system-level systemd services"
else
  SYSTEMD_DIR="$HOME_DIR/.config/systemd/user"
  SYSTEMCTL="systemctl --user"
  mkdir -p "$SYSTEMD_DIR"
  info "Running as user: user-level systemd services"
  # Enable lingering so services survive logout
  if command -v loginctl &>/dev/null; then
    loginctl enable-linger "$CURRENT_USER" 2>/dev/null || true
  fi
fi

# =============================================================================
# Generate systemd service files
# =============================================================================

SERVICES_INSTALLED=()

ENV_VARS="Environment=PATH=$(dirname "$DENO_BIN"):/usr/local/bin:/usr/bin:/bin
Environment=DENO_DIR=${HOME_DIR}/.cache/deno
Environment=HOME=$HOME_DIR
Environment=IKSIR_CONFIG_DIR=$CONFIG_DIR
Environment=IKSIR_STATE_DIR=$DATA_DIR
Environment=IKSIR_LOG_DIR=$STATE_DIR
Environment=IKSIR_REPO_PATH=$REPO_PATH"

# --- MCP Server ---
cat > "$SYSTEMD_DIR/iksir-mcp.service" <<EOF
[Unit]
Description=Iksir MCP Server
After=network.target

[Service]
Type=simple
WorkingDirectory=$REPO_PATH
ExecStart=$DENO_BIN run --allow-all --env=.env src/mcp/serve.ts --port=$MCP_PORT
Restart=on-failure
RestartSec=5
$ENV_VARS

[Install]
WantedBy=multi-user.target
EOF
SERVICES_INSTALLED+=(iksir-mcp)
info "Generated iksir-mcp.service"

# --- Agent Runtime ---
cat > "$SYSTEMD_DIR/iksir-agent.service" <<EOF
[Unit]
Description=Iksir Agent Runtime (OpenCode)
After=network.target iksir-mcp.service
Requires=iksir-mcp.service

[Service]
Type=simple
WorkingDirectory=$REPO_PATH
ExecStart=$OPENCODE_BIN serve --port $AGENT_PORT --hostname 0.0.0.0
Restart=on-failure
RestartSec=10
Environment=HOME=$HOME_DIR

[Install]
WantedBy=multi-user.target
EOF
SERVICES_INSTALLED+=(iksir-agent)
info "Generated iksir-agent.service"

# --- Daemon ---
cat > "$SYSTEMD_DIR/iksir.service" <<EOF
[Unit]
Description=Iksir
After=network.target iksir-agent.service
Requires=iksir-agent.service

[Service]
Type=simple
WorkingDirectory=$REPO_PATH
ExecStart=$DENO_BIN run --allow-all --env=.env src/main.ts
Restart=on-failure
RestartSec=10
$ENV_VARS

[Install]
WantedBy=multi-user.target
EOF
SERVICES_INSTALLED+=(iksir)
info "Generated iksir.service"

# --- Proxy (optional) ---
if [[ "$INSTALL_PROXY" == "yes" ]]; then
  cat > "$SYSTEMD_DIR/iksir-proxy.service" <<EOF
[Unit]
Description=Iksir SOCKS5 Proxy (WireGuard + gost)
After=network.target
Before=iksir-mcp.service

[Service]
Type=simple
ExecStartPre=/usr/bin/wg-quick up $PROXY_WG_IFACE
ExecStart=$PROXY_BIN -L socks5://:1080
ExecStopPost=/usr/bin/wg-quick down $PROXY_WG_IFACE
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

  sed -i 's/After=network.target$/After=network.target iksir-proxy.service/' "$SYSTEMD_DIR/iksir-mcp.service"
  sed -i '/\[Unit\]/a Requires=iksir-proxy.service' "$SYSTEMD_DIR/iksir-agent.service"

  SERVICES_INSTALLED+=(iksir-proxy)
  info "Generated iksir-proxy.service"
fi

# =============================================================================
# Deploy
# =============================================================================

$SYSTEMCTL daemon-reload
info "Reloaded systemd"

for svc in "${SERVICES_INSTALLED[@]}"; do
  $SYSTEMCTL enable "$svc.service" 2>/dev/null
done
info "Enabled services: ${SERVICES_INSTALLED[*]}"

echo ""
info "Installation complete."
echo ""
echo "  Start:    iksir start"
echo "  Stop:     iksir stop"
echo "  Status:   iksir status"
echo "  Restart:  iksir restart"
echo ""
echo "  Config:   $CONFIG_DIR/iksir.json"
echo "  Data:     $DATA_DIR/"
echo "  Logs:     $STATE_DIR/"
echo "  Env:      $REPO_PATH/.env"
echo ""
echo "  First time? Run ${BOLD}iksir init${RESET} for guided setup."
echo ""
info "Then: iksir start"
