{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "name": "@munadi/core",
  "version": "0.1.0",
  "exports": "./src/cli.ts",
  "tasks": {
    "munadi": "deno run --allow-all --env=.env src/cli.ts",
    "start": "deno run --allow-all --env=.env src/cli.ts start",
    "stop": "deno run --allow-all --env=.env src/cli.ts stop",
    "restart": "deno run --allow-all --env=.env src/cli.ts restart",
    "status": "deno run --allow-all --env=.env src/cli.ts status",
    "check": "deno run --allow-all --env=.env src/cli.ts check",
    "sync": "deno run --allow-all --env=.env src/cli.ts sync",
    "test": "deno test --allow-all",
    "typecheck": "deno check src/main.ts src/mcp/mun-server.ts src/mcp/serve.ts src/cli.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "@std/": "jsr:@std/",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/testing": "jsr:@std/testing@^1",
    "@opencode/sdk": "npm:@opencode-ai/sdk@^1.2.10",
    "@db/sqlite": "jsr:@db/sqlite@^0.12.0"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false,
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "include": ["no-unused-vars", "no-explicit-any", "prefer-const"]
    }
  }
}
