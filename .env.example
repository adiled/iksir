# Iksir Environment Configuration
# Copy to .env and fill in your values.

# =============================================================================
# Core
# =============================================================================

# Path to the repository Iksir manages (default: .)
# IKSIR_REPO_PATH=/path/to/your/project

# Configuration directory (default: $XDG_CONFIG_HOME/iksir or ~/.config/iksir)
# IKSIR_CONFIG_DIR=~/.config/iksir

# Data directory for SQLite DB (default: $XDG_DATA_HOME/iksir or ~/.local/share/iksir)
# IKSIR_STATE_DIR=~/.local/share/iksir

# Log directory (default: $XDG_STATE_HOME/iksir or ~/.local/state/iksir)
# IKSIR_LOG_DIR=~/.local/state/iksir

# =============================================================================
# Agent Runtime (OpenCode)
# =============================================================================

# OpenCode server URL (default: http://localhost:4096)
# IKSIR_OPENCODE_SERVER=http://localhost:4096

# MCP server port (default: 3100)
# IKSIR_MCP_PORT=3100

# =============================================================================
# Issue Tracker (Linear)
# =============================================================================

LINEAR_API_KEY=

# =============================================================================
# Telegram
# =============================================================================

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Forum-enabled supergroup (optional)
# TELEGRAM_GROUP_ID=

# Dispatch topic ID in the group (optional)
# TELEGRAM_DISPATCH_TOPIC_ID=

# SOCKS5 proxy for Telegram (optional, e.g. socks5://localhost:1080)
# TELEGRAM_PROXY=

# =============================================================================
# Ntfy (Push Notifications)
# =============================================================================

# NTFY_TOPIC=iksir
