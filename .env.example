# Munadi Environment Configuration
# Copy to .env and fill in your values.

# =============================================================================
# Munadi Core
# =============================================================================

# Path to the repository Munadi manages (default: .)
# MUNADI_REPO_PATH=/path/to/your/project

# Configuration directory (default: $XDG_CONFIG_HOME/munadi or ~/.config/munadi)
# MUNADI_CONFIG_DIR=~/.config/munadi

# Data directory for SQLite DB (default: $XDG_DATA_HOME/munadi or ~/.local/share/munadi)
# MUNADI_STATE_DIR=~/.local/share/munadi

# Log directory (default: $XDG_STATE_HOME/munadi or ~/.local/state/munadi)
# MUNADI_LOG_DIR=~/.local/state/munadi

# Log level: debug | info | warn | error (default: info)
# MUNADI_LOG_LEVEL=info

# MCP server port (default: 3100)
# MUNADI_MCP_PORT=3100

# Git user prefix for chore branches: chore branches become {user}/{identifier}
# Falls back to "dev" if not set.
# MUNADI_GIT_USER=dev

# Strategy to load: "default" (no extra tools), "ssp" (SSP/SSSP PR slicing),
# or a file path to a custom strategy module.
# MUNADI_STRATEGY=default

# =============================================================================
# Agent Guidelines
# =============================================================================

# Path to AGENTS.md injected into classification prompts.
# See agents.md.example for the template.
# MUNADI_AGENTS_MD_PATH=~/.config/munadi/AGENTS.md

# Override paths for classifier prompt templates (optional).
# Defaults to prompts/classify-notification.md and prompts/classify-question.md
# in MUNADI_REPO_PATH.
# MUNADI_CLASSIFY_NOTIFICATION_PROMPT=
# MUNADI_CLASSIFY_QUESTION_PROMPT=

# =============================================================================
# Agent Runtime (OpenCode)
# =============================================================================

# OpenCode server URL (default: http://localhost:4096)
# MUNADI_OPENCODE_SERVER=http://localhost:4096

# =============================================================================
# Issue Tracker (Linear by default)
# =============================================================================

# Issue tracker API key (Linear by default, required for ticket operations)
LINEAR_API_KEY=

# =============================================================================
# Telegram (Messaging)
# =============================================================================

# Telegram bot token (enables Telegram notifications)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID for direct messages to operator
TELEGRAM_CHAT_ID=

# Forum-enabled supergroup for Munadi operations (optional)
# TELEGRAM_GROUP_ID=

# Dispatch topic ID in the group (optional)
# TELEGRAM_DISPATCH_TOPIC_ID=

# SOCKS5 proxy URL for Telegram (optional, e.g., socks5://localhost:1080)
# TELEGRAM_PROXY=

# =============================================================================
# Ntfy (Push Notifications)
# =============================================================================

# Ntfy topic name (enables ntfy push notifications)
# NTFY_TOPIC=munadi
